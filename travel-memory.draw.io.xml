<mxfile host="app.diagrams.net">
  <diagram name="Travel Memory Architecture">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Travel Memory Application Deployment Architecture"
          style="text;html=1;fontSize=18;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="600" height="40" as="geometry"/>
        </mxCell>

        <!-- User -->
        <mxCell id="user" value="User (Browser)"
          style="shape=ellipse;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="50" y="300" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- Cloudflare -->
        <mxCell id="cf" value="Cloudflare (DNS)"
          style="rounded=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="220" y="300" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- ALB -->
        <mxCell id="alb" value="AWS ALB"
          style="rounded=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="420" y="300" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- EC2 Instance 1 -->
        <mxCell id="ec21" value="EC2 Instance 1"
          style="rounded=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="620" y="200" width="200" height="140" as="geometry"/>
        </mxCell>

        <!-- EC2 Instance 2 -->
        <mxCell id="ec22" value="EC2 Instance 2"
          style="rounded=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="620" y="380" width="200" height="140" as="geometry"/>
        </mxCell>

        <!-- Nginx -->
        <mxCell id="nginx" value="Nginx (Reverse Proxy)"
          style="rounded=1;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="650" y="230" width="140" height="40" as="geometry"/>
        </mxCell>

        <!-- Frontend -->
        <mxCell id="frontend" value="React App (Static Build)"
          style="rounded=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="620" y="550" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Backend -->
        <mxCell id="backend" value="Node.js (Express API)"
          style="rounded=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="860" y="230" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- MongoDB -->
        <mxCell id="mongo" value="MongoDB Atlas"
          style="shape=cylinder;fillColor=#ffe6cc;" vertex="1" parent="1">
          <mxGeometry x="1080" y="230" width="160" height="80" as="geometry"/>
        </mxCell>

        <!-- Edges with labels -->
        <mxCell id="e1" value="HTTPS Request" edge="1" parent="1" source="user" target="cf"
          style="endArrow=block;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" value="DNS Routing" edge="1" parent="1" source="cf" target="alb"
          style="endArrow=block;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" value="Load Balanced Traffic" edge="1" parent="1" source="alb" target="ec21"
          style="endArrow=block;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3b" value="Load Balanced Traffic" edge="1" parent="1" source="alb" target="ec22"
          style="endArrow=block;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" value="Routing" edge="1" parent="1" source="ec21" target="nginx"
          style="endArrow=block;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" value="Static Files" edge="1" parent="1" source="nginx" target="frontend"
          style="endArrow=block;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e6" value="/api Requests" edge="1" parent="1" source="nginx" target="backend"
          style="endArrow=block;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e7" value="DB Connection" edge="1" parent="1" source="backend" target="mongo"
          style="endArrow=block;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>